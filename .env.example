# === BySabel BI — Variáveis de Ambiente ===
# Copie este arquivo para ".env.local" e preencha os valores reais.
# NUNCA commite o .env.local (ele contém segredos).

# --- Microwork Cloud (fonte dos dados de vendas) ---
# Token Bearer usado pelo proxy /api/sales para autenticar na integração.
MICROWORK_TOKEN=

# --- Supabase (autenticação, perfis e metas) ---
# URL e chave pública (anon) do projeto Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
